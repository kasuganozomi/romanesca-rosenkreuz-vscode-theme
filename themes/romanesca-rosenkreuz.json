  "tokenColors": [
    {
      "name": "1. Comments",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "comment.block.documentation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#666666",
        "fontStyle": "italic"
      }
    },
    {
      "name": "2. Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.backtick",
        "string.template",
        "string.interpolated",
        "string.unquoted"
      ],
      "settings": {
        "foreground": "#ffbf00"
      }
    },
    {
      "name": "3. String escape",
      "scope": [
        "constant.character.escape",
        "constant.character.unicode"
      ],
      "settings": {
        "foreground": "#ff8c00"
      }
    },
    {
      "name": "4. Template expression",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#ff8c00"
      }
    },
    {
      "name": "5. Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.decimal",
        "constant.numeric.integer",
        "constant.numeric.hex",
        "constant.numeric.octal",
        "constant.numeric.binary",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#ff8c00"
      }
    },
    {
      "name": "6. Boolean/null/undefined",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.none",
        "constant.language.nan"
      ],
      "settings": {
        "foreground": "#17a398"
      }
    },
    {
      "name": "7. Other constants",
      "scope": [
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ffafd1"
      }
    },
    {
      "name": "8. class/interface/enum keyword",
      "scope": [
        "storage.type.class",
        "storage.type.interface",
        "storage.type.enum",
        "storage.type.struct",
        "storage.type.trait",
        "storage.type.module",
        "storage.type.namespace",
        "storage.type.record"
      ],
      "settings": {
        "foreground": "#7b2ff7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "9. Class names",
      "scope": [
        "entity.name.type.class",
        "entity.other.inherited-class",
        "entity.name.type.struct",
        "entity.name.type.trait",
        "entity.name.type.record"
      ],
      "settings": {
        "foreground": "#da80ff"
      }
    },
    {
      "name": "10. Interface/enum/type names + PHP types",
      "scope": [
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type",
        "entity.name.type.alias",
        "entity.name.type.primitive",
        "support.type",
        "support.class",
        "keyword.other.type.php",
        "storage.type.php",
        "support.type.php"
      ],
      "settings": {
        "foreground": "#17a398"
      }
    },
    {
      "name": "11. Constructor",
      "scope": [
        "keyword.control.constructor",
        "storage.type.function.constructor",
        "entity.name.function.constructor"
      ],
      "settings": {
        "foreground": "#cc2222"
      }
    },
    {
      "name": "12. Function/method names",
      "scope": [
        "entity.name.function",
        "support.function",
        "support.function.builtin",
        "meta.definition.method entity.name.function",
        "meta.function.expression entity.name.function"
      ],
      "settings": {
        "foreground": "#ff3333"
      }
    },
    {
      "name": "13. Access modifiers",
      "scope": [
        "storage.modifier",
